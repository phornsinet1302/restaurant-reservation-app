{
  "expo": {
    "name": "Seatly",
    "slug": "restaurant-reservation-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "primaryColor": "#D4A017",
    "backgroundColor": "#FFFFFF",
    "icon": "./assets/seatlylogo.png",
    "scheme": "restaurant-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.restaurant.tableorderapp",
      "infoPlist": {
        "NSAppleMusicUsageDescription": "Allow $(PRODUCT_NAME) to access your Apple Music library",
        "NSLocationWhenInUseUsageDescription": "We need your location to show nearby restaurants and track your journey to the restaurant.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "We need your location to show nearby restaurants and track your journey to the restaurant.",
        "LSApplicationQueriesSchemes": [
          "comgooglemaps"
        ]
      },
      "config": {
        "googleMapsApiKey": "AIzaSyCIkLAU412I5NDh_taEpWErZ7qRmDtCIbI"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/seatlylogo.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.restaurant.tableorderapp",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/seatlylogo.png"
    },
    "plugins": [
      [
        "react-native-maps",
        {
          "googleMapsApiKey": "AIzaSyA_H61Uv4BAl5FN4kx95Rolw-dKQdDk9pY"
        }
      ],
      "expo-router",
      "expo-font",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Seatly to access your photos to upload profile pictures and menu images.",
          "cameraPermission": "Allow Seatly to use your camera to take profile pictures and menu photos."
        }
      ],
      "expo-video",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "splash": {
      "image": "./assets/seatlylogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "aca6b8a0-d609-4401-86b2-5624941187bd"
      }
    }
  }
}

{
  "expo": {
    "name": "Restaurant Table & Order App",
    "slug": "restaurant-table-order-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "restaurant-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.restaurant.tableorderapp",
      "infoPlist": {
        "NSAppleMusicUsageDescription": "Allow $(PRODUCT_NAME) to access your Apple Music library",
        "NSLocationWhenInUseUsageDescription": "We need your location to show nearby restaurants and track your journey to the restaurant.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "We need your location to show nearby restaurants and track your journey to the restaurant."
      },
      "config": {
        "googleMapsApiKey": "AIzaSyCIkLAU412I5NDh_taEpWErZ7qRmDtCIbI"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.restaurant.tableorderapp",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "react-native-maps",
        {
          "googleMapsApiKey": "AIzaSyA_H61Uv4BAl5FN4kx95Rolw-dKQdDk9pY"
        }
      ],
      "expo-router",
      "expo-font",
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    }
  }
}
